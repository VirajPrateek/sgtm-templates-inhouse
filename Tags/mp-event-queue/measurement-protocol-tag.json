            "name": "fieldname",
            "type": "TEXT",
            "isUnique": true,
            "valueValidators": [
              {
                "type": "NON_EMPTY"
              }
            ]
          }
        ],
        "help": "Event parameters listed here will not be sent to Google.",
        "newRowButtonText": "+ Add param"
      },
      {
        "type": "SIMPLE_TABLE",
        "name": "eventParameters",
        "displayName": "Parameters to Add / Edit",
        "simpleTableColumns": [
